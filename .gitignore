# --- Large data artifacts (kept out of git; see README for how to obtain/rebuild) ---
# The built database (~1.9 GB) — rebuild with scripts/build_ipeds_db.py
ipeds.db
*.db
*.sqlite
*.sqlite3

# Source IPEDS Access files (~3.2 GB) — download from NCES, drop into data/
data/*.accdb
data/*.mdb

# App state DB (users, skills, chats) and staging rebuilds — never commit
app.db
app.db-*
ipeds_staging.db
ipeds.db-*
# Atomic-swap backup the importer leaves next to ipeds.db (repo root in local
# dev). NOT caught by *.db — it ends in .prev. ~1.9 GB; must never be committed.
*.db.prev
data/uploads/

# Generated query outputs
output/

# --- Secrets / config ---
.env
.env.*
!.env.example

# --- Node / frontend ---
# No trailing slash: that form matches only directories, so a *symlink* named
# node_modules slips past it and gets committed.
node_modules
frontend/dist/
*.tsbuildinfo

# --- Playwright e2e output ---
frontend/test-results/
frontend/playwright-report/

# --- Claude Code local settings (agent definitions in .claude/agents/ ARE tracked) ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.py[cod]
.venv
venv/
env/
.ipynb_checkpoints/

# --- Editor / OS cruft ---
.DS_Store
*.swp

# Local deployment data volume
srv-data/

# Local app.db backups (scripts/backup_app_db.py) — precious state lives off-site
backups/

# Local CI gate scratch (scripts/run_ci_local.sh)
.ci/
logs.db
logs.db-*

# coverage.py artifacts
.coverage
.coverage.*
htmlcov/
