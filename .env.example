# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- LLM (any OpenAI-compatible provider; OpenRouter by default) --------------
# See the README (Self-hosting) and CONTRIBUTING.md for provider selection, the
# OpenRouter allowlist/404 gotcha, and the flash->pro escalation guidance.
LLM_API_KEY=sk-or-...
LLM_BASE_URL=https://openrouter.ai/api/v1
MODEL_DEFAULT=deepseek/deepseek-v4-flash
MODEL_ESCALATION=deepseek/deepseek-v4-pro
# Max agent tool-call rounds per question before a final answer is forced.
# Raise it if complex, multi-step questions get cut off mid-analysis.
LLM_MAX_TOOL_ITERS=12
# Fallback token prices (USD per 1,000,000 tokens) for the Usage "Spend" total.
# Spend normally comes from the provider's per-request cost (OpenRouter reports
# it). If your provider does NOT report cost, Spend reads 0 — set these to your
# model's list prices to estimate it instead (prompt tokens * input + completion
# tokens * output). Leave at 0/unset when the provider reports cost. Note: the
# estimate does not discount cached-prefix tokens, so it slightly over-states
# spend when the prompt cache is running hot.
# LLM_INPUT_COST_PER_MTOK=0.27
# LLM_OUTPUT_COST_PER_MTOK=1.10
# Topical guardrail: a cheap pre-flight classifier refuses off-topic and
# prompt-injection messages before the agent runs. Set false to disable.
GUARD_ENABLED=true
# Server logs persist to a small SQLite store (logs.db, kept beside app.db unless
# LOG_DB_PATH is set) and are pruned after this many days.
LOG_RETENTION_DAYS=30
# ...and capped at this many rows, whichever bites first. Age alone is unbounded
# within its window: a log storm can run the file away in a day and the 30-day
# sweep won't touch it. 0 disables the cap. Freed space is returned to disk.
LOG_MAX_ROWS=50000
APP_PUBLIC_URL=https://ipeds.yourdomain.edu
# Attribution title sent to the LLM provider (OpenRouter's X-Title header).
LLM_APP_TITLE=IPEDS Oracle
# Fallback timezone (IANA name) for the admin usage graph when a request doesn't
# carry the viewer's own zone. Chat timestamps and the graph normally use the
# END-USER's browser timezone, so this is only a defensive default.
TIMEZONE=America/New_York
# Hides the chat's "don't enter proprietary/confidential info" privacy warning.
# Leave false unless the deploying organization has determined that its LLM
# provider, contract, deployment architecture, and data-use terms permit users
# to submit proprietary or confidential information. Setting this true only
# SUPPRESSES THE WARNING — it does not make the provider trustworthy or change
# any provider/model/logging/retention/data-handling behavior. Accepted true
# values (case-insensitive): true, t, yes, y, 1; everything else is false.
TRUST_LLM_PROVIDER=false

# --- Auth / sessions ----------------------------------------------------------
# true when the app is reached over HTTPS (behind a TLS-terminating reverse proxy
# or tunnel, or serving a self-signed cert). Set false ONLY for plain-HTTP local
# testing — a Secure cookie is never sent over HTTP, so logins would silently fail.
COOKIE_SECURE=true
# Comma-separated bootstrap admin emails (auto-allowlisted + admin on startup).
ADMIN_EMAILS=admin@yourdomain.edu
# Your institution's email domain. Strangers outside it can't file an access
# request (which would otherwise email every admin and burn Resend quota), and it
# supplies the login form's "you@..." hint. It does NOT gate sign-in — anyone on
# the allowlist gets their link whatever their domain, so a cross-domain admin or
# contractor still works. Leave blank to accept access requests from anywhere.
EMAIL_DOMAIN=yourdomain.edu
# Rate limit on POST /api/auth/request (defaults shown; tune if needed).
AUTH_RATE_WINDOW_SECONDS=900
AUTH_RATE_MAX_PER_EMAIL=5
AUTH_RATE_MAX_PER_IP=20
# Number of trusted reverse proxies / tunnels in front of the app. The per-IP
# rate limiter reads the real client IP from X-Forwarded-For, which is
# client-spoofable; a trusted proxy appends the real peer as the RIGHT-most hop,
# so we read the Nth entry from the right. Set to 1 behind a single reverse proxy
# or tunnel; 0 (dev / app reached directly) ignores X-Forwarded-For entirely and
# uses the socket peer.
TRUSTED_PROXY_COUNT=1

# --- Email --------------------------------------------------------------------
# Which transport delivers the sign-in / access-request / approval emails:
#   auto     pick resend if RESEND_API_KEY is set, else smtp if SMTP_HOST is set,
#            else console (log-only) — the default.
#   resend   a hosted email API — the easiest path for a pilot.
#   smtp     your own mail (Google Workspace, Microsoft 365, or any relay).
#   console  don't send; log the message (incl. the sign-in link) — dev only.
MAIL_BACKEND=auto
# The From address. Must be one the chosen backend is allowed to send as (a
# verified Resend domain, or an address your SMTP server/relay accepts).
MAIL_FROM=IPEDS Oracle <noreply@ipeds.yourdomain.edu>
# Where "request access" notices go (defaults to the first ADMIN_EMAILS entry).
ACCESS_REQUEST_TO=admin@yourdomain.edu

# Resend (used when MAIL_BACKEND=resend, or auto with a key present).
RESEND_API_KEY=re_...

# SMTP (used when MAIL_BACKEND=smtp, or auto with SMTP_HOST set). Examples:
#   Microsoft 365:    SMTP_HOST=smtp.office365.com   SMTP_PORT=587  (STARTTLS)
#   Google Workspace: SMTP_HOST=smtp-relay.gmail.com SMTP_PORT=587  (STARTTLS)
#                     (or smtp.gmail.com:587 with an app password)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USERNAME=noreply@yourdomain.edu
# SMTP_PASSWORD=...
# SMTP_STARTTLS=true      # STARTTLS on 587 (default). For implicit TLS on 465:
# SMTP_SSL=false          #   set SMTP_SSL=true, SMTP_PORT=465, SMTP_STARTTLS=false
# SMTP_TIMEOUT=15

# --- Query safety (optional overrides) ----------------------------------------
# SQL_TIMEOUT_SECONDS=25
# SQL_ROW_CAP_MODEL=200

# --- Data import (Admin -> Imports; optional overrides) -----------------------
# MAX_UPLOAD_MB=2048
# Where the NCES year-catalog "integrate" flow stages fetched .accdb files —
# deleted after every run (success or failure), so it just needs headroom, not
# persistence. Put it on the same volume as ipeds.db/data/ in production.
# NCES_WORK_DIR=./data/work
# NCES_HTTP_TIMEOUT_SECONDS=60
# NCES_ZIP_MAX_MB=512
# NCES_ACCDB_MAX_MB=3072
# NCES_TOTAL_MAX_MB=51200
# The system-prompt schema guide (defaults to docs/SCHEMA.md at the repo root).
# SCHEMA_MD_PATH=./docs/SCHEMA.md
# Disk/time preflight estimator (backend/app/estimate.py) calibration — backs the
# Imports tab's disk-headroom meter and run_integrate's pre-fetch refusal.
# NCES_ACCDB_EXPAND_FACTOR=3.0
# NCES_EST_BANDWIDTH_MBPS=10.0
# NCES_EST_BUILD_SECONDS_PER_YEAR=60.0
# NCES_DEFAULT_PER_YEAR_DB_MB=380
# NCES_DOWNLOAD_DEADLINE_SECONDS=1800
# NCES_DISK_SAFETY_FACTOR=1.2
# NCES_PROBE_CONCURRENCY=5
# NCES_DOWNLOAD_CONCURRENCY=5

# --- Deploy (Docker) ----------------------------------------------------------
# Which published image the app service runs. CI tags releases as vX.Y.Z and
# moves :latest to the newest release; pin an exact tag (e.g. v1.2.0) to freeze,
# or leave :latest and `docker compose pull` to take the current release.
# IPEDS_TAG=latest
#
# Optional — serve HTTPS directly with a self-signed cert instead of a reverse
# proxy/tunnel (see the README "Self-hosting" section). Generate one with
# scripts/gen-selfsigned-cert.sh, mount ./certs in compose.yaml, then set:
# SSL_CERTFILE=/certs/cert.pem
# SSL_KEYFILE=/certs/key.pem
