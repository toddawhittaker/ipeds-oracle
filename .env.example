# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- LLM (OpenRouter) ---------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...
MODEL_DEFAULT=deepseek/deepseek-chat
MODEL_ESCALATION=deepseek/deepseek-chat-v3.1
APP_PUBLIC_URL=https://ipeds.yourdomain.edu
APP_TITLE=IPEDS Query

# --- Auth / sessions ----------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=true
# Comma-separated bootstrap admin emails (auto-allowlisted + admin on startup).
ADMIN_EMAILS=todd@thewhittakers.org

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=re_...
MAIL_FROM=IPEDS Query <noreply@ipeds.yourdomain.edu>
# Where "request access" notices go (defaults to the first ADMIN_EMAILS entry).
ACCESS_REQUEST_TO=todd@thewhittakers.org

# --- Query safety (optional overrides) ----------------------------------------
# SQL_TIMEOUT_SECONDS=25
# SQL_ROW_CAP_MODEL=200
