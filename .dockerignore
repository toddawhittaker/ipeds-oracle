# Keep the build context small — data + local artifacts never go into the image.
.git
.venv
ipeds.db
ipeds.db-*
ipeds_staging.db
app.db
app.db-*
data/
output/
frontend/node_modules
frontend/dist
# docs/ is excluded EXCEPT SCHEMA.md, which the image needs (system prompt).
docs/*
!docs/SCHEMA.md
__pycache__/
*.pyc
.env
.env.*
